# Realtime Gateway — Environment Variables
# Copy to .env and fill in your values

# Google Cloud
GCP_PROJECT_ID=your-gcp-project-id

# Gemini API (required)
GEMINI_API_KEY=your-gemini-api-key

# Gateway authentication secret (shared with Swift client)
GATEWAY_AUTH_SECRET=any-random-secret-string

# ADK Orchestrator URL (local or Cloud Run)
ADK_ORCHESTRATOR_URL=http://localhost:8081

# Firestore collection for action state (optional, defaults to "action_states")
ACTION_STATE_FIRESTORE_COLLECTION=action_states

# Server port (optional, defaults to 8080)
PORT=8080
