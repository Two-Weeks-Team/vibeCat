                    "filter": "resource.type=\"generic_node\" AND metric.type=\"workload.googleapis.com/vibecat.gateway.fallback.requests\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_DELTA"
                    }
                  }
                }
              }
            ],
            "timeshiftDuration": "0s",
            "yAxis": {
              "label": "requests",
              "scale": "LINEAR"
