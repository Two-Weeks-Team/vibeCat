flowchart TB
    subgraph CLIENT["macOS Client — Swift 6.2"]
        direction LR
        UI["Cat UI\n+ Voice Chat"] --> SC["Screen\nCapture"] --> AX["Accessibility\nNavigator"] --> OV["Navigator\nOverlay"]
    end

    subgraph GATEWAY["Realtime Gateway — Go · Cloud Run"]
        direction LR
        WS["WebSocket\n/ws/live"] --> LIVE["Gemini Live\nSession"] --> FC["5 FC Tools"] --> PFC["pendingFC\nQueue"] --> HEAL["Self-Healing\nmax 2 retries"] --> CDP["Chrome DevTools\nchromedp"]
    end

    subgraph CLOUD["Google Cloud Platform"]
        direction LR
        GEM["Gemini Live API\nVoice + Vision + FC"] --> ADK["ADK Orchestrator\nScreenshot Analysis"] --> FIRE["Firestore\n+ Logging"] --> LOG["Cloud Trace\n+ Monitoring"]
    end

    CLIENT -->|"voice + screenshots"| GATEWAY
    GATEWAY <-->|"multimodal stream + function calls"| CLOUD
    GATEWAY -->|"desktop + browser actions"| CLIENT
    CLOUD -->|"verify + escalate"| GATEWAY

